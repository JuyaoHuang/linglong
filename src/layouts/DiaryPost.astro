---
import type { MarkdownHeading } from 'astro'
import type { CollectionEntry } from 'astro:content'

// Plugin styles
import 'katex/dist/katex.min.css'
import 'lxgw-wenkai-lite-webfont/style.css'

import { MediumZoom } from 'astro-pure/advanced'
import { ArticleBottom, TOC } from 'astro-pure/components/pages'
import config from 'virtual:config'
import PageLayout from '@/layouts/ContentLayout.astro'
import DiaryHero from '@/components/diary/DiaryHero.astro'

interface Props {
  post: CollectionEntry<'diary'>
  posts: CollectionEntry<'diary'>[]
  headings: MarkdownHeading[]
  remarkPluginFrontmatter: Record<string, unknown>
}

const {
  post: { id, data },
  posts,
  headings,
  remarkPluginFrontmatter
} = Astro.props

const {
  description,
  heroImage,
  publishDate,
  title,
  updatedDate
} = data

const socialImage = heroImage
  ? typeof heroImage.src === 'string'
    ? heroImage.src
    : heroImage.src.src
  : config.socialCard
const articleDate = updatedDate?.toISOString() ?? publishDate.toISOString()
const primaryColor = data.heroImage?.color ?? 'hsl(var(--primary) / var(--un-text-opacity))'
---

<PageLayout
  meta={{ articleDate, description, ogImage: socialImage, title }}
  highlightColor={primaryColor}
  back='/diary_notes'
>
  {!!headings.length && <TOC {headings} slot='sidebar' />}

  <DiaryHero {data} {remarkPluginFrontmatter} slot='header' />

  <slot />

  <Fragment slot='bottom'>
    {/* Article recommend */}
    <ArticleBottom collections={posts} {id} class='mt-3 sm:mt-6' />
  </Fragment>

  <slot name='bottom-sidebar' slot='bottom-sidebar' />
</PageLayout>

{config.integ.mediumZoom.enable && <MediumZoom />}

<script define:vars={{ diaryId: id }}>
  // Interactive checkboxes with Neon DB persistence
  document.addEventListener('DOMContentLoaded', async () => {
    const checkboxes = document.querySelectorAll('.prose input[type="checkbox"]')
    if (!checkboxes.length) return

    // Load saved states from API
    try {
      const res = await fetch(`/api/diary-tasks?diary_id=${encodeURIComponent(diaryId)}`)
      if (res.ok) {
        const saved = await res.json()
        checkboxes.forEach((cb, i) => {
          if (saved[i] !== undefined) {
            cb.checked = saved[i]
            if (cb.checked) cb.closest('li')?.classList.add('task-done')
          }
        })
      }
    } catch {}

    // Enable interaction
    checkboxes.forEach((cb, i) => {
      cb.removeAttribute('disabled')
      cb.style.cursor = 'pointer'

      cb.addEventListener('change', async () => {
        if (cb.checked) {
          cb.closest('li')?.classList.add('task-done')
        } else {
          cb.closest('li')?.classList.remove('task-done')
        }

        try {
          await fetch('/api/diary-tasks', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              diary_id: diaryId,
              task_index: i,
              checked: cb.checked
            })
          })
        } catch {}
      })
    })
  })
</script>

<style is:global>
  .prose .diary-poetry-section,
  .prose .diary-poetry-section * {
    font-family: 'LXGW WenKai Lite', sans-serif;
  }

  .prose li.task-done {
    text-decoration: line-through;
    opacity: 0.6;
  }
  .prose input[type="checkbox"] {
    width: 1em;
    height: 1em;
    margin-right: 0.4em;
    vertical-align: middle;
    accent-color: hsl(var(--primary));
  }
</style>
