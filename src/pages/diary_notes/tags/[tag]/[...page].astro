---
import { Paginator, PostPreview } from 'astro-pure/components/pages'
import { getBlogCollection, getUniqueTags, sortMDByDate } from 'astro-pure/server'
import { Button } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'
import config from '@/site-config'

export const prerender = false

const { tag, page: pageParam } = Astro.params
if (!tag) return Astro.redirect('/diary_notes/tags')

const allPosts = sortMDByDate(await getBlogCollection('diary'))
const uniqueTags = getUniqueTags(allPosts)

if (!uniqueTags.includes(tag)) return Astro.redirect('/diary_notes/tags')

const filterPosts = allPosts.filter((post) => post.data.tags.includes(tag))
const currentPage = pageParam ? parseInt(pageParam) : 1
if (isNaN(currentPage) || currentPage < 1) return Astro.redirect(`/diary_notes/tags/${tag}`)

const pageSize = config.content.blogPageSize || 8
const totalPages = Math.ceil(filterPosts.length / pageSize)
if (currentPage > totalPages && totalPages > 0) return Astro.redirect(`/diary_notes/tags/${tag}`)

const start = (currentPage - 1) * pageSize
const pagePosts = filterPosts.slice(start, start + pageSize)

const meta = {
  description: `View all diary entries with the tag - ${tag}`,
  title: `Diary Tag: ${tag}`
}

const prevUrl = currentPage > 1
  ? { text: '← Previous', url: currentPage === 2 ? `/diary_notes/tags/${tag}` : `/diary_notes/tags/${tag}/${currentPage - 1}` }
  : undefined
const nextUrl = currentPage < totalPages
  ? { text: 'Next →', url: `/diary_notes/tags/${tag}/${currentPage + 1}` }
  : undefined
---

<PageLayout {meta}>
  <Button title='Back' href='/diary_notes' variant='back' />
  <main class='mt-6 lg:mt-10'>
    <div id='content-header' class='animate'>
      <h1 class='mb-6 flex items-end gap-x-2 text-3xl font-medium'>
        Tags:
        <span class='text-2xl'>#{tag}</span>
      </h1>
    </div>

    <section id='content' class='animate' aria-label='Diary entry list'>
      <ul class='flex flex-col gap-y-3 text-start'>
        {pagePosts.map((post) => <PostPreview post={post} detailed basePath='/diary_notes' />)}
      </ul>
      <Paginator {...{ prevUrl, nextUrl }} />
    </section>
  </main>
</PageLayout>
