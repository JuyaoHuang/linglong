---
// MonthCalendar.astro — Monthly calendar with blue dots for todo days
---

<div class="month-calendar">
  <div class="cal-header">
    <button id="cal-prev" class="cal-nav" aria-label="Previous month">&lt;</button>
    <h3 id="cal-title" class="text-sm font-medium"></h3>
    <button id="cal-next" class="cal-nav" aria-label="Next month">&gt;</button>
  </div>
  <div class="cal-weekdays">
    <span>日</span><span>一</span><span>二</span><span>三</span>
    <span>四</span><span>五</span><span>六</span>
  </div>
  <div id="cal-days" class="cal-days"></div>
</div>

<style>
  .month-calendar {
    padding: 1rem;
    border-radius: var(--un-radius, 1rem);
    border: 1px solid hsl(var(--border));
    background: hsl(var(--background));
    min-width: 280px;
  }
  .cal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
  }
  .cal-nav {
    background: none;
    border: 1px solid hsl(var(--border));
    border-radius: 0.375rem;
    padding: 0.25rem 0.5rem;
    cursor: pointer;
    color: hsl(var(--foreground));
    transition: background 0.15s;
  }
  .cal-nav:hover {
    background: hsl(var(--muted));
  }
  .cal-weekdays {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    text-align: center;
    font-size: 0.75rem;
    color: hsl(var(--muted-foreground));
    margin-bottom: 0.25rem;
  }
  .cal-days {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 2px;
  }
  #cal-days :global(.cal-day) {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 0.375rem 0;
    border-radius: 0.375rem;
    font-size: 0.8125rem;
    cursor: pointer;
    transition: background 0.15s;
    min-height: 2.25rem;
  }
  #cal-days :global(.cal-day:hover) {
    background: hsl(var(--muted));
  }
  #cal-days :global(.cal-day.today) {
    font-weight: 600;
    color: hsl(var(--primary));
  }
  #cal-days :global(.cal-day.selected) {
    background: hsl(var(--primary) / 0.15);
    color: hsl(var(--primary));
    font-weight: 600;
  }
  #cal-days :global(.cal-day.other-month) {
    opacity: 0.3;
  }
  #cal-days :global(.cal-dot) {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: hsl(210 80% 55%);
    margin-top: 2px;
  }
</style>

<script>
  let currentYear: number
  let currentMonth: number
  let selectedDate: string | null = null
  let todoDates = new Set<string>()

  function initCalendar() {
    const now = new Date()
    currentYear = now.getFullYear()
    currentMonth = now.getMonth()

    document.getElementById('cal-prev')?.addEventListener('click', () => {
      currentMonth--
      if (currentMonth < 0) { currentMonth = 11; currentYear-- }
      renderCalendar()
    })
    document.getElementById('cal-next')?.addEventListener('click', () => {
      currentMonth++
      if (currentMonth > 11) { currentMonth = 0; currentYear++ }
      renderCalendar()
    })

    loadTodoDates().then(() => renderCalendar())
  }

  function toLocalDateStr(raw: string): string {
    const d = new Date(raw)
    return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`
  }

  async function loadTodoDates() {
    try {
      const res = await fetch('/api/todos')
      if (!res.ok) return
      const todos: any[] = await res.json()
      todoDates.clear()
      for (const t of todos) {
        if (t.due_date) todoDates.add(toLocalDateStr(t.due_date))
      }
    } catch {}
  }

  function renderCalendar() {
    const title = document.getElementById('cal-title')
    const grid = document.getElementById('cal-days')
    if (!title || !grid) return

    const monthNames = ['一月','二月','三月','四月','五月','六月',
      '七月','八月','九月','十月','十一月','十二月']
    title.textContent = `${currentYear}年 ${monthNames[currentMonth]}`

    const firstDay = new Date(currentYear, currentMonth, 1).getDay()
    const daysInMonth = new Date(currentYear, currentMonth + 1, 0).getDate()
    const todayDate = new Date()
    const today = `${todayDate.getFullYear()}-${String(todayDate.getMonth() + 1).padStart(2, '0')}-${String(todayDate.getDate()).padStart(2, '0')}`

    grid.innerHTML = ''

    // Previous month padding
    const prevDays = new Date(currentYear, currentMonth, 0).getDate()
    for (let i = firstDay - 1; i >= 0; i--) {
      const d = prevDays - i
      const el = createDayEl(d, true, '')
      grid.appendChild(el)
    }

    // Current month
    for (let d = 1; d <= daysInMonth; d++) {
      const dateStr = `${currentYear}-${String(currentMonth + 1).padStart(2, '0')}-${String(d).padStart(2, '0')}`
      const el = createDayEl(d, false, dateStr)
      if (dateStr === today) el.classList.add('today')
      if (dateStr === selectedDate) el.classList.add('selected')
      if (todoDates.has(dateStr)) {
        const dot = document.createElement('span')
        dot.className = 'cal-dot'
        el.appendChild(dot)
      }
      grid.appendChild(el)
    }

    // Next month padding
    const totalCells = grid.children.length
    const remaining = totalCells % 7 === 0 ? 0 : 7 - (totalCells % 7)
    for (let d = 1; d <= remaining; d++) {
      const el = createDayEl(d, true, '')
      grid.appendChild(el)
    }
  }

  function createDayEl(day: number, otherMonth: boolean, dateStr: string) {
    const el = document.createElement('div')
    el.className = 'cal-day' + (otherMonth ? ' other-month' : '')
    el.textContent = String(day)
    if (dateStr) {
      el.dataset.date = dateStr
      el.addEventListener('click', () => {
        selectedDate = dateStr
        renderCalendar()
        window.dispatchEvent(new CustomEvent('calendar:select', { detail: { date: dateStr } }))
      })
    }
    return el
  }

  document.addEventListener('DOMContentLoaded', initCalendar)
  document.addEventListener('astro:page-load', initCalendar)
  window.addEventListener('todos:updated', () => {
    loadTodoDates().then(() => renderCalendar())
  })
</script>
