---
// WeatherWidget.astro — Floating weather card in left viewport margin
// Only visible on PC screens >1400px
// Uses Open-Meteo API (free, no key required)
---

<div id="weather-widget" class="weather-widget">
  <div class="weather-header">
    <span id="weather-city" class="text-sm font-medium">加载中...</span>
    <div class="header-actions">
      <button id="weather-refresh" class="refresh-btn" aria-label="刷新天气">↻</button>
      <button id="weather-close" class="refresh-btn" aria-label="关闭天气面板">✕</button>
    </div>
  </div>

  <div id="weather-current" class="weather-current">
    <div class="current-temp">
      <span id="weather-temp" class="text-3xl font-light">--</span>
      <span class="text-sm text-muted-foreground">°C</span>
    </div>
    <div class="current-details text-xs text-muted-foreground">
      <span id="weather-desc"></span>
      <span id="weather-humidity"></span>
      <span id="weather-wind"></span>
    </div>
  </div>

  <div class="chart-container">
    <canvas id="weather-chart" width="260" height="120"></canvas>
  </div>

  <div class="weather-footer">
    <input type="text" id="weather-city-input" placeholder="输入城市名..."
      class="city-input" />
  </div>

  <div id="weather-hourly" class="weather-hourly hidden">
    <div class="hourly-header">
      <span class="text-xs font-medium">今日逐时天气</span>
      <button id="hourly-close" class="refresh-btn" aria-label="关闭">✕</button>
    </div>
    <div class="hourly-chart-container">
      <canvas id="hourly-chart" width="260" height="100"></canvas>
    </div>
    <div id="hourly-list" class="hourly-list"></div>
  </div>
</div>

<style>
  .weather-widget {
    position: fixed;
    left: 1.5rem;
    top: 50%;
    transform: translateY(-50%);
    width: 280px;
    padding: 1rem;
    border-radius: 1rem;
    border: 1px solid hsl(var(--border));
    background: hsl(var(--background) / 0.8);
    backdrop-filter: blur(12px);
    box-shadow: 0 4px 24px hsl(var(--foreground) / 0.06);
    z-index: 40;
    display: none;
    opacity: 0;
    transition: opacity 0.4s ease-out;
    pointer-events: none;
  }
  .weather-widget.weather-loaded {
    opacity: 1;
    pointer-events: auto;
  }
  @media (min-width: 1400px) {
    .weather-widget { display: block; }
  }
  .weather-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
  }
  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }
  .refresh-btn {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 1rem;
    color: hsl(var(--muted-foreground));
    padding: 0.125rem;
    transition: color 0.15s;
  }
  .refresh-btn:hover { color: hsl(var(--foreground)); }
  .weather-current {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 0.75rem;
  }
  .current-temp {
    display: flex;
    align-items: flex-start;
    gap: 0.125rem;
  }
  .current-details {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.125rem;
  }
  #weather-chart {
    width: 100%;
    height: 100%;
  }
  .chart-container {
    position: relative;
    width: 100%;
    height: 120px;
    margin-bottom: 0.5rem;
  }
  .weather-footer {
    border-top: 1px solid hsl(var(--border));
    padding-top: 0.5rem;
  }
  .city-input {
    width: 100%;
    padding: 0.375rem 0.5rem;
    border-radius: 0.375rem;
    border: 1px solid hsl(var(--border));
    background: transparent;
    color: hsl(var(--foreground));
    font-size: 0.75rem;
  }
  .city-input:focus {
    outline: none;
    border-color: hsl(var(--primary));
  }
  .weather-hourly {
    border-top: 1px solid hsl(var(--border));
    padding-top: 0.5rem;
    margin-top: 0.5rem;
    max-height: 260px;
    overflow-y: auto;
    transition: all 0.3s ease;
  }
  .weather-hourly.hidden {
    display: none;
  }
  .hourly-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.375rem;
  }
  .hourly-chart-container {
    position: relative;
    width: 100%;
    height: 100px;
    margin-bottom: 0.375rem;
  }
  #hourly-chart {
    width: 100%;
    height: 100%;
  }
  .hourly-list {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }
  .hourly-list :global(.hourly-item) {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.625rem;
    color: hsl(var(--muted-foreground));
    padding: 0.125rem 0;
    gap: 1rem;
  }
  .hourly-list :global(.hour-time) { width: 2.5rem; }
  .hourly-list :global(.hour-temp) { font-weight: 500; color: hsl(var(--foreground)); }

</style>

<script>
  import { Chart, LineController, BarController, LineElement, BarElement, PointElement, CategoryScale, LinearScale, Tooltip, Filler } from 'chart.js'

  Chart.register(LineController, BarController, LineElement, BarElement, PointElement, CategoryScale, LinearScale, Tooltip, Filler)

  const WMO_CODES: Record<number, string> = {
    0: '晴', 1: '大部晴朗', 2: '多云', 3: '阴天',
    45: '雾', 48: '雾凇', 51: '小毛毛雨', 53: '毛毛雨',
    55: '大毛毛雨', 61: '小雨', 63: '中雨', 65: '大雨',
    71: '小雪', 73: '中雪', 75: '大雪', 80: '小阵雨',
    81: '阵雨', 82: '大阵雨', 95: '雷暴'
  }

  let chartInstance: Chart | null = null
  let hourlyChartInstance: Chart | null = null
  let cachedHourly: any = null

  async function geocodeCity(city: string) {
    const res = await fetch(
      `https://geocoding-api.open-meteo.com/v1/search?name=${encodeURIComponent(city)}&count=1`
    )
    const data = await res.json()
    if (!data.results?.length) return null
    const r = data.results[0]
    return { lat: r.latitude, lon: r.longitude, name: r.name }
  }

  async function fetchWeather(lat: number, lon: number) {
    const url = `https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lon}&current=temperature_2m,relative_humidity_2m,wind_speed_10m,weather_code&daily=temperature_2m_max,temperature_2m_min,precipitation_sum&hourly=temperature_2m,relative_humidity_2m,weather_code&timezone=auto&forecast_days=4`
    const res = await fetch(url)
    return res.json()
  }

  function renderChart(daily: any) {
    const canvas = document.getElementById('weather-chart') as HTMLCanvasElement
    if (!canvas) return

    if (chartInstance) chartInstance.destroy()

    const labels = daily.time.map((d: string) => {
      const date = new Date(d)
      return date.toLocaleDateString('zh-CN', { weekday: 'short' })
    })

    const isDark = document.documentElement.classList.contains('dark')
    const textColor = isDark ? 'rgba(255,255,255,0.6)' : 'rgba(0,0,0,0.5)'

    chartInstance = new Chart(canvas, {
      type: 'bar',
      data: {
        labels,
        datasets: [
          {
            type: 'line',
            label: '最高温',
            data: daily.temperature_2m_max,
            borderColor: 'hsl(0, 70%, 60%)',
            backgroundColor: 'hsla(0, 70%, 60%, 0.1)',
            borderWidth: 2,
            pointRadius: 3,
            tension: 0.3,
            fill: false,
            yAxisID: 'y'
          },
          {
            type: 'line',
            label: '最低温',
            data: daily.temperature_2m_min,
            borderColor: 'hsl(210, 70%, 60%)',
            backgroundColor: 'hsla(210, 70%, 60%, 0.1)',
            borderWidth: 2,
            pointRadius: 3,
            tension: 0.3,
            fill: false,
            yAxisID: 'y'
          },
          {
            type: 'bar',
            label: '降水量',
            data: daily.precipitation_sum,
            backgroundColor: 'hsla(210, 80%, 55%, 0.3)',
            borderRadius: 2,
            yAxisID: 'y1'
          }
        ]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: { mode: 'index', intersect: false },
        plugins: {
          tooltip: { enabled: true },
        },
        scales: {
          x: {
            ticks: { color: textColor, font: { size: 10 } },
            grid: { display: false }
          },
          y: {
            position: 'left',
            ticks: {
              color: textColor,
              font: { size: 10 },
              callback: (v: any) => v + '°'
            },
            grid: { color: isDark ? 'rgba(255,255,255,0.05)' : 'rgba(0,0,0,0.05)' }
          },
          y1: {
            position: 'right',
            ticks: {
              color: textColor,
              font: { size: 10 },
              callback: (v: any) => v + 'mm'
            },
            grid: { display: false },
            min: 0
          }
        }
      }
    })
  }

  function getTodayHourly(hourly: any): { hours: string[], temps: number[], humids: number[], codes: number[] } {
    const today = new Date().toISOString().slice(0, 10)
    const hours: string[] = [], temps: number[] = [], humids: number[] = [], codes: number[] = []
    for (let i = 0; i < hourly.time.length; i++) {
      if (hourly.time[i].startsWith(today)) {
        hours.push(hourly.time[i].slice(11, 16))
        temps.push(hourly.temperature_2m[i])
        humids.push(hourly.relative_humidity_2m[i])
        codes.push(hourly.weather_code[i])
      }
    }
    return { hours, temps, humids, codes }
  }

  function renderHourlyPanel(hourly: any) {
    const panel = document.getElementById('weather-hourly')
    if (!panel) return

    const { hours, temps, humids, codes } = getTodayHourly(hourly)
    if (!hours.length) return

    // Render hourly chart
    const canvas = document.getElementById('hourly-chart') as HTMLCanvasElement
    if (canvas) {
      if (hourlyChartInstance) hourlyChartInstance.destroy()
      const isDark = document.documentElement.classList.contains('dark')
      const textColor = isDark ? 'rgba(255,255,255,0.6)' : 'rgba(0,0,0,0.5)'
      // Show every 3 hours for readability
      const step = 3
      const filteredLabels = hours.filter((_, i) => i % step === 0)
      const filteredTemps = temps.filter((_, i) => i % step === 0)

      hourlyChartInstance = new Chart(canvas, {
        type: 'line',
        data: {
          labels: filteredLabels,
          datasets: [{
            label: '温度',
            data: filteredTemps,
            borderColor: 'hsl(30, 80%, 55%)',
            backgroundColor: 'hsla(30, 80%, 55%, 0.1)',
            borderWidth: 1.5,
            pointRadius: 2,
            tension: 0.3,
            fill: true
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: { tooltip: { enabled: true } },
          scales: {
            x: { ticks: { color: textColor, font: { size: 9 } }, grid: { display: false } },
            y: { ticks: { color: textColor, font: { size: 9 }, callback: (v: any) => v + '°' }, grid: { color: isDark ? 'rgba(255,255,255,0.05)' : 'rgba(0,0,0,0.05)' } }
          }
        }
      })
    }

    // Render hourly list (every 3 hours)
    const listEl = document.getElementById('hourly-list')
    if (listEl) {
      listEl.innerHTML = ''
      for (let i = 0; i < hours.length; i += 3) {
        const item = document.createElement('div')
        item.className = 'hourly-item'
        const desc = WMO_CODES[codes[i]] || '未知'
        item.innerHTML = `<span class="hour-time">${hours[i]}</span><span class="hour-temp">${Math.round(temps[i])}°C</span><span>${desc}</span><span>${humids[i]}%</span>`
        listEl.appendChild(item)
      }
    }

    panel.classList.remove('hidden')
  }

  function updateUI(data: any, cityName: string) {
    const cityEl = document.getElementById('weather-city')
    const tempEl = document.getElementById('weather-temp')
    const descEl = document.getElementById('weather-desc')
    const humidEl = document.getElementById('weather-humidity')
    const windEl = document.getElementById('weather-wind')

    if (cityEl) cityEl.textContent = cityName
    if (tempEl) tempEl.textContent = String(Math.round(data.current.temperature_2m))
    if (descEl) descEl.textContent = WMO_CODES[data.current.weather_code] || '未知'
    if (humidEl) humidEl.textContent = `湿度: ${data.current.relative_humidity_2m}%`
    if (windEl) windEl.textContent = `风速: ${data.current.wind_speed_10m} km/h`

    renderChart(data.daily)

    // Cache hourly data for click interaction
    cachedHourly = data.hourly

    const widget = document.getElementById('weather-widget')
    if (widget) widget.classList.add('weather-loaded')
  }

  async function loadWeather(lat?: number, lon?: number, city?: string) {
    try {
      let name = city || '当前位置'
      if (!lat || !lon) {
        // Try geolocation
        const pos = await new Promise<GeolocationPosition>((resolve, reject) => {
          navigator.geolocation.getCurrentPosition(resolve, reject, { timeout: 5000 })
        })
        lat = pos.coords.latitude
        lon = pos.coords.longitude
      }
      const data = await fetchWeather(lat, lon)
      updateUI(data, name)
    } catch {
      const cityEl = document.getElementById('weather-city')
      if (cityEl) cityEl.textContent = '请在下方输入城市'
    }
  }

  function initWeather() {
    const saved = localStorage.getItem('weather-city')
    if (saved) {
      const { lat, lon, name } = JSON.parse(saved)
      loadWeather(lat, lon, name)
    } else {
      loadWeather()
    }

    document.getElementById('weather-refresh')?.addEventListener('click', () => {
      const saved = localStorage.getItem('weather-city')
      if (saved) {
        const { lat, lon, name } = JSON.parse(saved)
        loadWeather(lat, lon, name)
      } else {
        loadWeather()
      }
    })

    const input = document.getElementById('weather-city-input') as HTMLInputElement
    input?.addEventListener('keydown', async (e) => {
      if (e.key !== 'Enter') return
      const city = input.value.trim()
      if (!city) return
      const geo = await geocodeCity(city)
      if (geo) {
        localStorage.setItem('weather-city', JSON.stringify(geo))
        loadWeather(geo.lat, geo.lon, geo.name)
        input.value = ''
      }
    })

    // Click on daily chart to show today's hourly detail
    const chartCanvas = document.getElementById('weather-chart') as HTMLCanvasElement
    chartCanvas?.addEventListener('click', (e) => {
      if (!chartInstance || !cachedHourly) return
      const points = chartInstance.getElementsAtEventForMode(e, 'index', { intersect: false }, false)
      if (points.length > 0 && points[0].index === 0) {
        const panel = document.getElementById('weather-hourly')
        if (panel?.classList.contains('hidden')) {
          renderHourlyPanel(cachedHourly)
        } else {
          panel?.classList.add('hidden')
        }
      }
    })

    // Close hourly panel
    document.getElementById('hourly-close')?.addEventListener('click', () => {
      document.getElementById('weather-hourly')?.classList.add('hidden')
    })

    // Close entire weather widget
    document.getElementById('weather-close')?.addEventListener('click', () => {
      const widget = document.getElementById('weather-widget')
      if (widget) {
        widget.classList.remove('weather-loaded')
        setTimeout(() => { widget.style.display = 'none' }, 400)
      }
    })
  }

  document.addEventListener('DOMContentLoaded', initWeather)
  document.addEventListener('astro:page-load', initWeather)
</script>
