---
import { Button, Collapse, Spoiler, Timeline } from 'astro-pure/user'
import PageLayout from '@/layouts/CommonPage.astro'
import Substats from '@/components/about/Substats.astro'
import ToolSection from '@/components/about/ToolSection.astro'
import Signature from '../../../preset/components/signature/Signature.astro'

const headings = [
  { depth: 2, slug: 'skills', text: 'Skills' },
  { depth: 2, slug: 'tools', text: 'Tools' },
  { depth: 2, slug: 'social-networks', text: 'Social Networks' },
  { depth: 2, slug: 'education', text: 'Education' },
  { depth: 2, slug: 'about-blog', text: 'About Blog' }
]
---

<PageLayout title='About' {headings} comment>
  <p>Developer / AI Engineer</p>
  <p>
    一名热爱编程的<span class="line-through text-muted-foreground">全栈开发者</span>，目前正在向 AI 应用开发方向发展。
  </p>
  <p>
    现在正在学习 Java ，期望系统性了解后端开发的相关知识，扩展自己的深度。
  </p>
  <p>
    我的兴趣主要在 NLP / 语音克隆 方向。
  </p>
  <div class="flex items-start gap-3 p-3 mt-4 rounded-lg bg-muted/30 border border-border/50">
    <span class="i-ri-lightbulb-flash-line text-xl text-yellow-500 mt-0.5 shrink-0"></span>
    
    <div class="flex flex-col sm:flex-row sm:items-center gap-2 ">
      <span class="font-serif italic text-base text-foreground">
        Gaze forward , transcending the self of yesterday.
      </span>
      <span class="text-base opacity-80 italic">
        <!-- <Spoiler>提及少年一词，应与平庸相斥</Spoiler> -->
        <Spoiler>事以密成，语以泄败，是故话不可多言，福不可多晒。</Spoiler>
      </span>
    </div>
  </div>
  <!-- <Button title='Sponsor Me' class='w-fit' href='/projects#sponsorship' variant='ahead' /> -->
  
  <h2 id='Skills'>Skills</h2>
  <div>
    <!-- AI & Backend -->
    <ToolSection
      class='mb-5'
      title='AI & Backend'
      tools={[
        {
          name: 'PyTorch',
          description: 'Deep Learning Framework',
          href: 'https://pytorch.org/',
          icon: import('@/assets/tools/pytorch.svg?raw')
        },
        {
          name: 'FastAPI',
          description: 'High Performance API',
          href: 'https://fastapi.tiangolo.com/',
          icon: import('@/assets/tools/fastapi.svg?raw')
        },
        // {
        //   name: 'Java',
        //   description: 'Learning System Design',
        //   href: 'https://www.java.com/',
        //   icon: import('@/assets/tools/java.svg?raw')
        // }
      ]}
    />

    <!-- Embedded & Edge -->
    <ToolSection
      class='mb-5'
      title='Embedded & IoT'
      tools={[
        {
          name: 'STM32',
          description: '',
          href: 'https://www.st.com/',
          icon: import('@/assets/tools/stm32.svg?raw')
        },
        {
          name: 'Raspberry Pi',
          description: '',
          href: 'https://www.raspberrypi.org/',
          icon: import('@/assets/tools/raspberrypi.svg?raw')
        },
        {
          name: 'Embedded AI',
          description: '',
          href: '#',
          icon: import('@/assets/tools/tensorflow.svg?raw') 
        }
      ]}
    />

    <!-- Frontend -->
    <ToolSection
      class='mb-5'
      title='Frontend'
      tools={[
        {
          name: 'Vue.js',
          description: 'Progressive Framework',
          href: 'https://vuejs.org/',
          icon: import('@/assets/tools/vue.svg?raw')
        }
      ]}
    />
  </div>
