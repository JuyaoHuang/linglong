---
import { PostPreview } from 'astro-pure/components/pages'
import { getBlogCollection, groupCollectionsByYear, sortMDByDate } from 'astro-pure/server'
import { Button } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'

export const prerender = false

const allPosts = await getBlogCollection('diary')
const allPostsByDate = sortMDByDate(allPosts)
const allPostsByYear = groupCollectionsByYear(allPostsByDate)

const meta = {
  description: 'All diary entries by year',
  title: 'Diary Archives'
}
---

<PageLayout {meta}>
  <Button title='Back' href='/diary_notes' variant='back' />

  <main class='mt-6 lg:mt-10'>
    <div id='content-header' class='animate'>
      <h1 class='mb-6 text-3xl font-medium'>Diary Archives</h1>
    </div>

    {allPosts.length === 0 && <p>No diary entries yet.</p>}

    <section id='content' class='animate' aria-label='Diary entry list'>
      {
        allPostsByYear.map(([year, posts]) => (
          <div class='relative mt-20'>
            <h2
              class='absolute -start-6 -top-16 z-0 text-9xl font-bold text-transparent opacity-12 dark:opacity-25'
              style='-webkit-text-stroke-width:2px;-webkit-text-stroke-color:hsl(var(--foreground)/var(--un-text-opacity))'
            >
              <samp>{year}</samp>
            </h2>
            <p class='px-5 text-muted-foreground'>
              {posts.length} entr{posts.length > 1 ? 'ies' : 'y'}
            </p>
            <ul class='flex flex-col text-start'>
              {posts.map((p) => (
                <PostPreview post={p} class='border-0 bg-transparent py-2' basePath='/diary_notes' />
              ))}
            </ul>
          </div>
        ))
      }
    </section>
  </main>
</PageLayout>
